{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "intake-pending-proposal",
  "title": "Intake Pending-Proposal Frontmatter",
  "description": "Schema for .claude/stakeholder/pending-proposal/<id>.md YAML frontmatter",
  "type": "object",
  "required": ["id", "source", "trust_tier", "user_id", "created_at", "state", "round", "content_hash"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[0-9]{8}-[0-9]{6}-[a-z0-9-]{1,40}$",
      "description": "ISO-Timestamp + slug, e.g. 20260512-143000-my-feature"
    },
    "source": {
      "type": "string",
      "enum": ["tier-1", "tier-2"],
      "description": "Stakeholder trust source"
    },
    "trust_tier": {
      "type": "integer",
      "enum": [1, 2],
      "description": "Numeric trust tier"
    },
    "user_id": {
      "type": "string",
      "minLength": 1,
      "description": "Telegram user ID or local identifier"
    },
    "created_at": {
      "type": "string",
      "description": "ISO-8601 UTC timestamp"
    },
    "state": {
      "type": "string",
      "const": "pending-proposal"
    },
    "round": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3,
      "description": "Round counter, MAX_INTAKE_ROUNDS=3"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "description": "SHA-256 hex digest for spam dedup"
    }
  }
}
