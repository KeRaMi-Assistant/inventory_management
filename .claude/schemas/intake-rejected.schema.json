{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "intake-rejected",
  "title": "Intake Rejected Frontmatter",
  "description": "Schema for .claude/stakeholder/rejected/<id>.md YAML frontmatter",
  "type": "object",
  "required": ["id", "state", "rejected_by", "rejected_at", "council_verdict_was"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[0-9]{8}-[0-9]{6}-[a-z0-9-]{1,40}$"
    },
    "state": {
      "type": "string",
      "const": "rejected"
    },
    "rejected_by": {
      "type": "string",
      "const": "user",
      "description": "Who rejected the proposal"
    },
    "rejected_at": {
      "type": "string",
      "description": "ISO-8601 UTC timestamp of rejection"
    },
    "user_reason": {
      "type": "string",
      "description": "Optional user-provided reason for rejection"
    },
    "council_verdict_was": {
      "type": "string",
      "enum": ["propose", "propose-with-changes", "reject", "needs-full-council"],
      "description": "The original council verdict before user rejected"
    }
  }
}
