{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "intake-superseded",
  "title": "Intake Superseded (Round-Advance) Frontmatter",
  "description": "Schema for .claude/stakeholder/pending-approval/<id>.superseded.md YAML frontmatter — atomic mv before each round advance",
  "type": "object",
  "required": [
    "id", "source", "trust_tier", "user_id",
    "created_at", "council_finished_at", "state", "verdict",
    "round", "council_cost_usd", "hmac_token",
    "pushed_at", "requires_human_dispute", "touches", "created_from",
    "superseded_at", "superseded_by_round"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[0-9]{8}-[0-9]{6}-[a-z0-9-]{1,40}$"
    },
    "source": {
      "type": "string",
      "enum": ["tier-1", "tier-2"]
    },
    "trust_tier": {
      "type": "integer",
      "enum": [1, 2]
    },
    "user_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "description": "ISO-8601 UTC timestamp"
    },
    "council_finished_at": {
      "type": "string",
      "description": "ISO-8601 UTC timestamp when council completed"
    },
    "state": {
      "type": "string",
      "const": "pending-approval",
      "description": "Still pending-approval at the time of supersession"
    },
    "verdict": {
      "type": "string",
      "enum": ["propose", "propose-with-changes", "reject", "needs-full-council"]
    },
    "round": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3,
      "description": "Round that is being superseded"
    },
    "council_cost_usd": {
      "type": "number",
      "minimum": 0
    },
    "hmac_token": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "pushed_at": {
      "type": ["string", "null"]
    },
    "requires_human_dispute": {
      "type": "boolean"
    },
    "touches": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_from": {
      "type": "string",
      "const": "intake-council"
    },
    "superseded_at": {
      "type": "string",
      "description": "ISO-8601 UTC timestamp when mv happened (atomic round advance)"
    },
    "superseded_by_round": {
      "type": "integer",
      "minimum": 2,
      "maximum": 3,
      "description": "The new round that replaces this file"
    }
  }
}
