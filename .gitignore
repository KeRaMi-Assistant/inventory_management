# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store

# Claude Code working files
.claude/last-task.txt
.claude/cache/
.claude/test-runs/
.claude/backlog/runs/
.claude/backlog/.lock

# Self-Mod / Integrity transient state (manifest itself IS tracked)
.claude/.user-session-active
.claude/integrity/check.out.log
.claude/integrity/check.err.log
.claude/overseer/PANIC
.claude/audit/self-mod.log
# Overseer runtime state (PANIC file above; full state dir ignored)
.claude/overseer/state/
# Analyzer module caches
.claude/analyzer/cache/
# Analyzer module state (runtime JSON, .gitkeep tracked)
.claude/analyzer/state/*.json

# Local test/dev secrets
.env.test
.env.local
.env.headless

# Supabase local state
supabase/.branches/
supabase/.temp/

# Playwright artifacts
playwright-report/
test-results/
.playwright-mcp/
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Phase 0+1 runtime artifacts (autonomous-swarm)
.claude/audit/.audit.ratelimit
.claude/audit/[0-9]*.md
.claude/audit/.audit.lock
.claude/overseer/notifications/queued.jsonl
.claude/overseer/notifications/sent.jsonl
.claude/overseer/notifications/dedup.jsonl
.claude/overseer/cost-ledger.jsonl
.claude/overseer/state/
.claude/state/

# Telegram-bot daemon logs + state (state/ already ignored above, listed for clarity)
.claude/overseer/telegram-bot.out.log
.claude/overseer/telegram-bot.err.log
