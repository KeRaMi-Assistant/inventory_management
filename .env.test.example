# Lokale Test-Credentials für Browser-Smoke-Tests via Playwright-MCP.
# Kopiere diese Datei zu `.env.test` und trage die echten Test-Account-Daten ein.
# `.env.test` ist gitignored — niemals committen, niemals echte Werte hier eintragen.

TEST_USER_EMAIL=replace-me@example.com
TEST_USER_PW=replace-me

TEST_USER2_EMAIL=replace-me2@example.com
TEST_USER2_PW=replace-me

# Flutter-Web-Server-Port (default 8123)
FLUTTER_WEB_PORT=8123

# TA0c (Plan 2026-05-14_strict_tracking_smoke_audit): Allowlist-E-Mail
# für den authentifizierten Test-Mode-Override `reset_cooldown` in der
# Edge-Function `inbox-parse`. Nur dieser Account darf den Re-Parse-
# Cooldown auf seinen eigenen Workspaces resetten — gebraucht für den
# Smoke-Audit S3 (Rate-Limit-Test).
#
# WICHTIG: Diese Variable wird in der Edge-Function gelesen, NICHT
# lokal in `.env.test`. Vor jedem Audit-Run gegen die Dev-Function setzen:
#
#   supabase secrets set AUDIT_TEST_USER_EMAIL=test@test.com
#
# NIEMALS gegen Prod setzen. Ist die Variable unset, ist der Override
# effektiv aus (Allowlist ist leer, jeder Caller bekommt 403).
AUDIT_TEST_USER_EMAIL=
