# Lokale Test-Credentials für Browser-Smoke-Tests via Playwright-MCP.
# Kopiere diese Datei zu `.env.test` und trage die echten Test-Account-Daten ein.
# `.env.test` ist gitignored — niemals committen, niemals echte Werte hier eintragen.

TEST_USER_EMAIL=replace-me@example.com
TEST_USER_PW=replace-me

TEST_USER2_EMAIL=replace-me2@example.com
TEST_USER2_PW=replace-me

# Flutter-Web-Server-Port (default 8123)
FLUTTER_WEB_PORT=8123
