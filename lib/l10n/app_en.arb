  "helpDiscordStep1Desc": "Discord → Settings → Advanced → enable Developer Mode.",
  "helpDiscordStep2Title": "Copy server ID",
  "helpDiscordStep2Desc": "Right-click the server name → \"Copy server ID\".",
  "helpDiscordStep3Title": "Add server ID to a buyer",
  "helpDiscordStep3Desc": "Settings → Buyers tab → edit buyer → Discord server IDs.",
  "helpDiscordConfiguredIds": "Configured server IDs",
  "helpDiscordNoBuyers": "No buyers yet",
  "helpDiscordNoBuyersDesc": "Add buyers in Settings to attach server IDs.",
