# Optional config for the headless-runner. Copy to .env.headless
# (gitignored) and fill in.

# Mobile push notifications via ntfy.sh (kostenlos, kein Account):
# 1. Wähle ein eindeutiges Topic, z.B. mit `uuidgen | tr '[:upper:]' '[:lower:]'`
# 2. Auf dem iPhone/Android: ntfy-App installieren, Topic abonnieren
# 3. Hier eintragen
# NTFY_TOPIC=

# Override Defaults:
# HEADLESS_MAX_BUDGET_USD=5
# HEADLESS_MODEL=sonnet
# HEADLESS_PERMISSION_MODE=auto

# Supabase Personal Access Token für MCP-Server (read-only DB-Queries
# für Sub-Claudes). Token erstellen unter:
#   https://supabase.com/dashboard/account/tokens
# WICHTIG: das ist NICHT die project-ref! Project-Ref steht in .mcp.json.
# Token-Format: sbp_xxxxx... — beginnt mit "sbp_".
# SUPABASE_ACCESS_TOKEN=sbp_REPLACE_ME
